    "urgent": {
      "keywords": [
        "chest pain",
        "difficulty breathing",
        "shortness of breath",
        "seizure",
        "overdose",
        "car accident",
        "crash",
        "broken",
        "fracture",
        "bleeding",
        "pregnant",
        "labor",
        "asthma"
      ]
    },
    "non_urgent": {
      "meta_triggers": {
        "false_alarm_eq": 1
      },
      "keywords": [
        "minor",
        "small cut",
        "non emergency",
        "noise complaint",
        "false alarm"
      ]
    },
    "default": "URGENT"
  },
  "slot_extraction_regex": {
    "age": [
      "\\b(\\d{1,3})\\s*(?:yo|y/o|years?\\s*old)\\b",
      "\\baged?\\s*(\\d{1,3})\\b"
    ],
    "sex": [
      "\\b(male|female|man|woman|boy|girl)\\b"
    ],
    "duration_minutes": [
      "\\bfor\\s*(\\d{1,3})\\s*(minutes?|mins?)\\b",
      "\\b(\\d{1,3})\\s*(minutes?|mins?)\\s*ago\\b",
      "\\bfor\\s*(\\d{1,2})\\s*(hours?|hrs?)\\b"
    ],
    "severity_1_10": [
      "\\b(\\d{1,2})\\s*/\\s*10\\b",
      "\\bpain\\s*(?:is|at)\\s*(\\d{1,2})\\b"
    ],
    "location_hint": [
      "\\b(at|in)\\s+(home|an apartment|a store|the street|a parking lot|a restaurant)\\b"
    ],
    "red_flags": [
      "\\bnot breathing\\b",
      "\\bunconscious\\b",
      "\\bcardiac arrest\\b",
      "\\bstroke\\b",
      "\\banaphylaxis\\b",
      "\\bsevere bleeding\\b"
    ]
  }
